{
  "name": "bungo-zundamon",
  "version": "0.1.0",
  "private": true,
  "description": "青空文庫の台詞をずんだもん音声で楽しむ静的Webアプリ",
  "type": "module",
  "engines": {
    "node": "24.11.0",
    "npm": "11.6.1"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run typecheck && vite build",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview --host 0.0.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
