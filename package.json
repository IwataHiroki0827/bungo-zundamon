{
  "name": "bungo-zundamon",
  "version": "0.1.0",
  "private": true,
  "description": "青空文庫の台詞をずんだもん音声で楽しむ静的Webアプリ",
  "type": "module",
  "engines": {
    "node": "24.11.0",
    "npm": "11.6.1"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node scripts/build-offline.mjs",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm test && npm run build",
    "verify:build": "node scripts/verify-project.mjs",
    "preview": "vite preview --host 127.0.0.1 --strictPort",
    "preview:pages": "npm run build && vite preview --host 127.0.0.1 --strictPort",
    "content:update": "node --experimental-transform-types scripts/content-cli.ts all",
    "content:bibliography": "node --experimental-transform-types scripts/content-cli.ts bibliography",
    "content:select": "node --experimental-transform-types scripts/content-cli.ts select",
    "content:sources": "node --experimental-transform-types scripts/content-cli.ts sources",
    "content:provenance": "node --experimental-transform-types scripts/content-cli.ts provenance",
    "content:decode": "node --experimental-transform-types scripts/content-cli.ts decode",
    "content:extract": "node --experimental-transform-types scripts/content-cli.ts extract",
    "content:normalize": "node --experimental-transform-types scripts/content-cli.ts normalize",
    "content:review:check": "node --experimental-transform-types scripts/content-cli.ts review",
    "content:voice:preflight": "node --experimental-transform-types scripts/content-cli.ts voice-preflight",
    "content:voice": "node --experimental-transform-types scripts/content-cli.ts voice",
    "content:build": "node --experimental-transform-types scripts/content-cli.ts build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
